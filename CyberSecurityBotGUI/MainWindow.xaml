<Window x:Class="CyberSecurityBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Security Awareness Bot"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Background="DarkSlateGray">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="139"/>
            <ColumnDefinition Width="111"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <ScrollViewer Grid.Column="0"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled" Grid.ColumnSpan="2" Margin="0,0,56,0" Height="684" VerticalAlignment="Bottom">
            <StackPanel Grid.Column="0" Background="DarkSlateGray" Grid.ColumnSpan="2" Margin="-5,-10,5,10" RenderTransformOrigin="0.509,0.463" Width="173">

                <!-- BOT IMAGE -->

                <!-- BOT IMAGE -->


                <Image Source="/images/bot.png"
                   Width="205"
                   Height="211"
                   />

                <Separator Margin="10"/>

                <!-- PART 2 -->

                <Button x:Name="PhishingButton"
                    Content=" Phishing"
                    Margin="8"
                    Height="40"
                    Background="#1565C0"
                    Click="PhishingButton_Click"/>

                <Button x:Name="MalwareButton"
                    Content=" Malware"
                    Margin="8"
                    Height="40"
                     Background="Red"
                    Click="MalwareButton_Click"/>

                <Button x:Name="PasswordButton"
                    Content=" Password Safety"
                    Margin="8"
                    Height="40"
                         Background="Green"
                    Click="PasswordButton_Click"/>

                <Button x:Name="PrivacyButton"
                    Content=" Privacy"
                    Margin="8"
                    Height="40"
                     Background="Yellow"
                    Click="PrivacyButton_Click"/>

                <Button x:Name="ScamButton"
                    Content=" Scam Awareness"
                    Margin="8"
                    Height="40"
                     Background="HotPink"
                    Click="ScamButton_Click"/>

                <Separator Margin="10"/>

                <!-- PART 3 -->

                <Button x:Name="AddTaskButton"
                    Content=" Add Task"
                    Margin="8"
                    Height="40"
                    Background="#1565C0"
                    Click="AddTaskButton_Click"/>

                <Button x:Name="ViewTaskButton"
                    Content="View Tasks"
                    Margin="8"
                    Height="40"
                    Background="Red"
                    Click="ViewTaskButton_Click"/>

                <Button x:Name="QuizButton"
                    Content=" Start Quiz"
                    Margin="8"
                    Height="40"
                      Background="Green"
                    Click="QuizButton_Click"/>

                <Button x:Name="LogButton"
                    Content="Activity Log"
                    Margin="8"
                    Height="40"
                      Background="Yellow"
                    Click="LogButton_Click"/>

                <Button x:Name="ClearButton"
                    Content="Clear Chat"
                    Margin="8"
                    Height="40"
                     Background="HotPink"
                    Click="ClearButton_Click"/>

            </StackPanel>

        </ScrollViewer>

        <!-- RIGHT SIDE -->

        <Grid Grid.Column="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Border Grid.Row="0"
                    Background="Red"
                    Margin="5">

                <TextBlock Text="Cyber Security Awareness Chatbot"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="Blue"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

            </Border>

            <!-- CHAT -->

            <TextBox Name="ChatArea"
                     Grid.Row="1"
                     Margin="10"
                     FontSize="15"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                      Background="LimeGreen"
                     VerticalScrollBarVisibility="Auto"/>

            <!-- INPUT -->

            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBox Name="UserInput"
                         Grid.Column="0"
                         Margin="10"
                          Background="AntiqueWhite"
                         FontSize="15"/>

                <Button Name="SendButton"
                        Grid.Column="1"
                        Margin="10"
                        Content="Send"
                         Background="blue"
                        Click="SendButton_Click"/>

            </Grid>

        </Grid>

    </Grid>

</Window>