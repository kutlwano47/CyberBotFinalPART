<Window x:Class="CyberSecurityBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Security Awareness Bot"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#EAEFF2">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="139"/>
            <ColumnDefinition Width="111"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <StackPanel Grid.Column="0" Background="#263238" Grid.ColumnSpan="2" Margin="-5,-10,5,10">

            <!-- BOT IMAGE -->


            <Image Source="/images/bot.png"
                   Width="138"
                   Height="42"
                   />

            <Separator Margin="10"/>

            <!-- PART 2 -->

            <Button Name="PhishingButton"
                    Content="🎣 Phishing"
                    Margin="8"
                    Height="40"
                    Click="PhishingButton_Click"/>

            <Button Name="MalwareButton"
                    Content="🦠 Malware"
                    Margin="8"
                    Height="40"
                    Click="MalwareButton_Click"/>

            <Button Name="PasswordButton"
                    Content="🔑 Password Safety"
                    Margin="8"
                    Height="40"
                    Click="PasswordButton_Click"/>

            <Button Name="PrivacyButton"
                    Content="🔒 Privacy"
                    Margin="8"
                    Height="40"
                    Click="PrivacyButton_Click"/>

            <Button Name="ScamButton"
                    Content="⚠ Scam Awareness"
                    Margin="8"
                    Height="40"
                    Click="ScamButton_Click"/>

            <Separator Margin="10"/>

            <!-- PART 3 -->

            <Button Name="AddTaskButton"
                    Content="📋 Add Task"
                    Margin="8"
                    Height="40"
                    Click="AddTaskButton_Click"/>

            <Button Name="ViewTaskButton"
                    Content="📂 View Tasks"
                    Margin="8"
                    Height="40"
                    Click="ViewTaskButton_Click"/>

            <Button Name="QuizButton"
                    Content="🎮 Start Quiz"
                    Margin="8"
                    Height="40"
                    Click="QuizButton_Click"/>

            <Button Name="LogButton"
                    Content="📝 Activity Log"
                    Margin="8"
                    Height="40"
                    Click="LogButton_Click"/>

            <Button Name="ClearButton"
                    Content="🗑 Clear Chat"
                    Margin="8"
                    Height="40"
                    Click="ClearButton_Click"/>

        </StackPanel>

        <!-- RIGHT SIDE -->

        <Grid Grid.Column="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Border Grid.Row="0"
                    Background="#1565C0"
                    Margin="5">

                <TextBlock Text="Cyber Security Awareness Chatbot"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

            </Border>

            <!-- CHAT -->

            <TextBox Name="ChatArea"
                     Grid.Row="1"
                     Margin="10"
                     FontSize="15"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>

            <!-- INPUT -->

            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBox Name="UserInput"
                         Grid.Column="0"
                         Margin="10"
                         FontSize="15"/>

                <Button Name="SendButton"
                        Grid.Column="1"
                        Margin="10"
                        Content="Send"
                        Click="SendButton_Click"/>

            </Grid>

        </Grid>

    </Grid>

</Window>